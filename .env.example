# ============================================================
# Balcu Hub — variables de entorno
# Copia a .env.local para desarrollo
# Configura las mismas variables en Vercel → Settings → Environment Variables
# ============================================================

# --- Neon Postgres (obligatorio) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# --- NextAuth / Google OAuth (obligatorio para admin) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-un-secreto-largo-aleatorio"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Admin (solo tu cuenta) ---
ADMIN_EMAIL="tu-email@gmail.com"
